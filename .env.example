# ═══════════════════════════════════════════════════════════════════════════
# Matrix OS · Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Kopyala → .env.local (dev için) veya Railway Variables dashboard (prod)
#
# IMPORTANT: Bu DOSYA commit edilir (.env.example), .env.local ASLA edilmez.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Core ──────────────────────────────────────────────────────────────────
# Railway Postgres plugin otomatik üretir; dev'de local Docker Postgres:
#   postgres://postgres:postgres@localhost:5432/matrix
DATABASE_URL="postgres://user:pass@host:5432/matrix"

# Railway Redis plugin otomatik üretir; dev'de local Docker Redis:
#   redis://localhost:6379
REDIS_URL="redis://user:pass@host:6379"

# ─── Auth (email allowlist — 3-5 kişi) ─────────────────────────────────────
# Virgülle ayrılmış email listesi. Sadece bu adresler Matrix'e erişebilir.
MATRIX_ALLOWED_EMAILS="ferhan@ferhan.co,partner@ferhan.co"

# Session cookie signing secret (üret: `openssl rand -hex 32`)
# Minimum 16 karakter. Production'da MUHAKKAK set et — aksi halde middleware
# bypass moduna geçer ve Matrix açık URL olur.
MATRIX_SESSION_SECRET="change-me-32-byte-random-hex"

# ─── Magic-link email (opsiyonel ama önerilen) ─────────────────────────────
# Ücretsiz 3K/ay: resend.com → API Keys → Create
# Yoksa: link Railway server log'una basılır, oradan kopyalarsın (ilk kurulum için OK)
RESEND_API_KEY=""
MATRIX_EMAIL_FROM="Matrix <noreply@ferhan.co>"

# ─── AI Layer ──────────────────────────────────────────────────────────────
# Matrix iki-AI mimarisi:
#   - ANTHROPIC (Claude): PRIMARY — agent execution, içerik üretimi, tool-use
#   - GEMINI (Google):    AUDIT    — Claude'un çıktısını denetleyici ikinci görüş
# Her external-send, her kritik karar, her SKILL/AGENT.md forge'u önce Claude
# üretir, sonra Gemini "cross-check audit" yapar. Dual-AI pattern holdco OS'un
# güvenlik omurgası.

ANTHROPIC_API_KEY="sk-ant-api03-..."
GEMINI_API_KEY=""                    # ai.google.dev — audit / second-opinion

# Opsiyonel fallback/alternatif modeller — The Engines üstünden:
GROQ_API_KEY=""                      # LPU wafer inference, cost-optimize routing
TOGETHER_API_KEY=""                  # open-source model serving
FIREWORKS_API_KEY=""                 # production-grade serverless
HUGGINGFACE_API_KEY=""               # HF Inference API + hub erişimi

# ─── Core Connectors (iterative olarak doldur) ─────────────────────────────
# Sadece gerçekten kullandığın connector'ların key'lerini koy; gerisi boş kalabilir.
NOTION_TOKEN=""
SLACK_BOT_TOKEN=""
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
HUBSPOT_API_KEY=""
STRIPE_SECRET_KEY=""
LINEAR_API_KEY=""

# ─── Observability (opsiyonel) ─────────────────────────────────────────────
SENTRY_DSN=""
AXIOM_TOKEN=""

# ─── Feature flags ─────────────────────────────────────────────────────────
# Geçiş fazında: true = DB'den oku, false = mock-data.ts'den oku
NEXT_PUBLIC_USE_DB="false"

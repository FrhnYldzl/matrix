# ═══════════════════════════════════════════════════════════════════════════
# Matrix OS · Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Kopyala → .env.local (dev için) veya Railway Variables dashboard (prod)
#
# IMPORTANT: Bu DOSYA commit edilir (.env.example), .env.local ASLA edilmez.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Core ──────────────────────────────────────────────────────────────────
# Railway Postgres plugin otomatik üretir; dev'de local Docker Postgres:
#   postgres://postgres:postgres@localhost:5432/matrix
DATABASE_URL="postgres://user:pass@host:5432/matrix"

# Railway Redis plugin otomatik üretir; dev'de local Docker Redis:
#   redis://localhost:6379
REDIS_URL="redis://user:pass@host:6379"

# ─── Auth (email allowlist — 3-5 kişi) ─────────────────────────────────────
# Virgülle ayrılmış email listesi. Sadece bu adresler Matrix'e erişebilir.
MATRIX_ALLOWED_EMAILS="ferhan@ferhan.co,partner@ferhan.co"

# Session cookie signing secret (production'da openssl rand -hex 32):
MATRIX_SESSION_SECRET="change-me-32-byte-random-hex"

# ─── Claude / LLM ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
# Opsiyonel fallback/alternatif modeller — Engines üstünden:
GROQ_API_KEY=""
TOGETHER_API_KEY=""
FIREWORKS_API_KEY=""
HUGGINGFACE_API_KEY=""

# ─── Core Connectors (iterative olarak doldur) ─────────────────────────────
# Sadece gerçekten kullandığın connector'ların key'lerini koy; gerisi boş kalabilir.
NOTION_TOKEN=""
SLACK_BOT_TOKEN=""
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
HUBSPOT_API_KEY=""
STRIPE_SECRET_KEY=""
LINEAR_API_KEY=""

# ─── Observability (opsiyonel) ─────────────────────────────────────────────
SENTRY_DSN=""
AXIOM_TOKEN=""

# ─── Feature flags ─────────────────────────────────────────────────────────
# Geçiş fazında: true = DB'den oku, false = mock-data.ts'den oku
NEXT_PUBLIC_USE_DB="false"
